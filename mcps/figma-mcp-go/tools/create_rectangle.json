{
  "name": "create_rectangle",
  "description": "Create a new rectangle on the current page or inside a parent node.",
  "inputSchema": {
    "properties": {
      "cornerRadius": {
        "description": "Corner radius in pixels",
        "type": "number"
      },
      "fillColor": {
        "description": "Fill color as hex e.g. #FF5733",
        "type": "string"
      },
      "height": {
        "description": "Height in pixels (default 100)",
        "type": "number"
      },
      "name": {
        "description": "Rectangle name",
        "type": "string"
      },
      "parentId": {
        "description": "Parent node ID in colon format. Defaults to current page.",
        "type": "string"
      },
      "width": {
        "description": "Width in pixels (default 100)",
        "type": "number"
      },
      "x": {
        "description": "X position (default 0)",
        "type": "number"
      },
      "y": {
        "description": "Y position (default 0)",
        "type": "number"
      }
    },
    "required": [],
    "type": "object"
  }
}